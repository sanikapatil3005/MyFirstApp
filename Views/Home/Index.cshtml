@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        background-color: #e6f2ff; /* light blue */
        font-family: Arial, sans-serif;
    }

    .container-box {
        background-color: white;
        padding: 30px;
        margin-top: 50px;
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
        display: inline-block;
    }

    h1 {
        color: #007acc;
        font-weight: bold;
    }

    p {
        font-size: 18px;
    }

    ul {
        text-align: left;
        margin-top: 20px;
    }

    li {
        margin: 8px 0;
        font-size: 16px;
    }
</style>

<div class="text-center">
    <div class="container-box">
        <h1 class="display-4">Hello Sanika 👋</h1>
        
        <p><b>Welcome to my first ASP.NET MVC project!</b></p>

        <p>
            This project demonstrates how to build and deploy a web application
            using ASP.NET Core and host it on a server.
        </p>

        <ul>
            <li>✔ ASP.NET MVC Architecture</li>
            <li>✔ Running on Local Server</li>
            <li>✔ Ready for AWS Deployment</li>
            <li>✔ Will be hosted using IIS</li>
        </ul>

        <p>
            Learn more about
            <a href="https://learn.microsoft.com/aspnet/core" target="_blank">
                ASP.NET Core Development
            </a>
        </p>
    </div>
</div>